<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#D5ECEC">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DRIVER VERIFICATION"
        android:textColor="#111212"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Plate Number"
        android:textColor="#41817E"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/dialogPlate"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/dialog_input_bg"
        android:hint="e.g. ABC-1234"
        android:padding="12dp"
        android:inputType="textCapCharacters"
        android:layout_marginBottom="16dp"
        android:textColor="#111212"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Driver's Password"
        android:textColor="#41817E"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/dialogPass"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/dialog_input_bg"
        android:hint="Enter PIN"
        android:padding="12dp"
        android:inputType="numberPassword"
        android:textColor="#111212"/>

</LinearLayout>