<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/allbg" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="TRIKE"
        android:textColor="#D5ECEC"
        android:textSize="44sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/textView6"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:layout_marginTop="60dp"/>

    <TextView
        android:id="@+id/textView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="SAFE"
        android:textColor="#111212"
        android:textSize="44sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/textView5"
        app:layout_constraintStart_toEndOf="@id/textView5"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:fontFamily="serif"
        android:text="Generate QR Code"
        android:textColor="#F3EDED"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textView6" />

    <EditText
        android:id="@+id/editTextText2_firstname"
        android:layout_width="294dp"
        android:layout_height="46dp"
        android:hint="First Name"
        android:textColorHint="#FEFEFE"
        android:textColor="#FEFEFE"
        android:backgroundTint="#FEFEFE"
        android:inputType="textCapWords"
        app:layout_constraintTop_toBottomOf="@id/textView2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <EditText
        android:id="@+id/editTextText2_middlename"
        android:layout_width="294dp"
        android:layout_height="46dp"
        android:hint="Middle Name"
        android:textColorHint="#FEFEFE"
        android:textColor="#FEFEFE"
        android:backgroundTint="#FEFEFE"
        android:inputType="textCapWords"
        app:layout_constraintTop_toBottomOf="@id/editTextText2_firstname"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"/>

    <EditText
        android:id="@+id/editTextText2_lastname"
        android:layout_width="294dp"
        android:layout_height="46dp"
        android:hint="Last Name"
        android:textColorHint="#FEFEFE"
        android:textColor="#FEFEFE"
        android:backgroundTint="#FEFEFE"
        android:inputType="textCapWords"
        app:layout_constraintTop_toBottomOf="@id/editTextText2_middlename"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"/>

    <EditText
        android:id="@+id/editTextNumber_plate"
        android:layout_width="291dp"
        android:layout_height="51dp"
        android:hint="Plate No."
        android:textColorHint="#FEFEFE"
        android:textColor="#FEFEFE"
        android:backgroundTint="#FEFEFE"
        android:inputType="textCapCharacters"
        app:layout_constraintTop_toBottomOf="@id/editTextText2_lastname"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <EditText
        android:id="@+id/editTextNumber_emergency"
        android:layout_width="291dp"
        android:layout_height="51dp"
        android:hint="Emergency No. (11 digits)"
        android:textColorHint="#FEFEFE"
        android:textColor="#FEFEFE"
        android:backgroundTint="#FEFEFE"
        android:inputType="number"
        android:maxLength="11"
        app:layout_constraintTop_toBottomOf="@id/editTextNumber_plate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/button"
        android:layout_width="239dp"
        android:layout_height="52dp"
        android:layout_marginBottom="50dp"
        android:backgroundTint="#41817E"
        android:text="Generate"
        android:textColor="#2B2D30"
        android:textStyle="bold"
        android:typeface="serif"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/imageButton5"
        android:layout_width="59dp"
        android:layout_height="52dp"
        android:backgroundTint="#397B77"
        app:srcCompat="@drawable/home"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>